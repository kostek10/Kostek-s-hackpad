{
    "manufacturer": "Konstanty",
    "keyboard_name": "Kostek's hackpad",
    "maintainer": "kostek10",
    "bootloader": "rp2040",
    "diode_direction": "COL2ROW",
    "features": {
        "bootmagic": true,
        "extrakey": true,
        "mousekey": true,
        "nkro": true
    },
    "matrix_pins": {
        "direct": [
            ["GP29", "GP28", null],
            ["GP4", "GP3", "GP27"]
        ]
    },
    "processor": "RP2040",
    "url": "https://github.com/kostek10/kostek-s-hackpad",
    "usb": {
        "device_version": "1.0.0",
        "pid": "0x0000",
        "vid": "0xFEED"
    },
    "layouts": {
        "LAYOUT": {
            "layout": [
                {"matrix": [0,0], "x": 0, "y": 0},
                {"matrix": [0,1], "x": 1, "y": 0},

                {"matrix": [1,0], "x": 0, "y": 1},
                {"matrix": [1,1], "x": 1, "y": 1},
                {"matrix": [1,2], "x": 2, "y": 1}
            ]
        }
    }
}